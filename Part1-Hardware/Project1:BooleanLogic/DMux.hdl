// File name: projects/1/DMux.hdl
/**
 * Demultiplexor:
 * [a, b] = [in, 0] if sel = 0
 *          [0, in] if sel = 1
 */
CHIP DMux {
    IN in, sel;
    OUT a, b;

    PARTS:
    Nand(a=sel,b=sel,out=nsel);
    Nand(a=nsel,b=in,out=nselNin);
    Nand(a=nselNin,b=nselNin,out=a);
    Nand(a=in,b=sel,out=inNsel);
    Nand(a=inNsel,b=inNsel,out=b);
}
