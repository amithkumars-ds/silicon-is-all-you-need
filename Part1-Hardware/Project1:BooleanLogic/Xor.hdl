// File name: projects/1/Xor.hdl
/**
 * Exclusive-or gate:
 * if ((a and Not(b)) or (Not(a) and b)) out = 1, else out = 0
 */
CHIP Xor{
    IN a,b;
    OUT out;

    PARTS:
    Nand(a=a,b=b,out=aNb);
    Nand(a=a,b=aNb,out=aNaNb);
    Nand(a=aNb,b=b,out=bNaNb);
    Nand(a=aNaNb,b=bNaNb,out=out);
}